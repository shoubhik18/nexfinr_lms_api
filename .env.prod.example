# ----------------------------------------------------------------------------
# lms-backend production environment
# Copy this file to `.env.prod` and fill in real values. NEVER commit `.env.prod`.
# ----------------------------------------------------------------------------

# Server
PORT=8080
NODE_ENV=production

# PostgreSQL connection string
DATABASE_URL=postgresql://lms_user:password@postgres-db:5432/lms_db
# true for RDS/cloud Postgres with TLS; false for local Docker Postgres (default)
DATABASE_SSL=false

# JWT secrets — use long random strings (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin(s) for CORS — comma-separated for multiple environments
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://your-frontend.example.com

# Public API base URL (used for uploaded asset links)
API_PUBLIC_URL=http://localhost:8080

# First admin seed
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=change_me_min_12_chars

# Default password for newly created users
DEFAULT_USER_PASSWORD=change_me_min_12_chars

# SMTP — required in production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="LMS Platform <your@gmail.com>"
