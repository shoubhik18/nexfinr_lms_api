# ----------------------------------------------------------------------------
# lms-backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ----------------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/lms_db

# JWT secrets — use long random strings (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin(s) for CORS — comma-separated for multiple environments
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://dev.lms.nexprocode.com,http://localhost:3000

# First admin seed (required for initial login in dev; required in production)
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=change_me_min_12_chars

# Default password for newly created users (required in production)
DEFAULT_USER_PASSWORD=change_me_min_12_chars

# SMTP — required in production; optional in development (emails are skipped if unset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="LMS Platform <your@gmail.com>"
